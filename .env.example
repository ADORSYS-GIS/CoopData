# ===========================================
# CoopData Environment Configuration
# ===========================================
# Copy this file to .env and adjust values.
# NEVER commit .env to version control.
# For production, generate strong random values for all secrets.

# ===========================================
# Database
# ===========================================
POSTGRES_USER=coopdata
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=coopdata
DATABASE_URL=postgresql://coopdata:change-me-in-production@postgres:5432/coopdata

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# Keycloak (OpenID Connect)
# ===========================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-in-production
KEYCLOAK_URL=http://keycloak:8180
KEYCLOAK_REALM=coop-data
KEYCLOAK_CLIENT_ID=coopdata-backend
KEYCLOAK_CLIENT_SECRET=change-me-in-production

# ===========================================
# Backend
# ===========================================
HOST=0.0.0.0
PORT=3000
JWT_ISSUER=http://keycloak:8180/realms/coop-data
# Aliases allow tokens issued via the public URL (browser) to be accepted by the backend (Docker internal)
JWT_ISSUER_ALIASES=http://localhost:8180/realms/coop-data
JWT_AUDIENCE=coopdata-frontend
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development

# ===========================================
# Frontend Build Args
# ===========================================
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=coop-data
VITE_KEYCLOAK_CLIENT_ID=coopdata-frontend

# ===========================================
# Keycloak Provisioning — Admin Users
# ===========================================

# DGRV Super Admin (platform owner, full access)
COOPDATA_DGRV_ADMIN_EMAIL=admin@dgrv.coop
COOPDATA_DGRV_ADMIN_PASSWORD=Dgrv@Admin2026!
COOPDATA_DGRV_ADMIN_FIRSTNAME=DGRV
COOPDATA_DGRV_ADMIN_LASTNAME=Administrator

# Ministry Admin (national oversight user)
COOPDATA_MINISTRY_ADMIN_EMAIL=admin@ministry.gov
COOPDATA_MINISTRY_ADMIN_PASSWORD=Ministry@Admin2026!
COOPDATA_MINISTRY_ADMIN_FIRSTNAME=Ministry
COOPDATA_MINISTRY_ADMIN_LASTNAME=Administrator
