# ===========================================
# CoopData Backend Configuration
# ===========================================
# Copy this file to .env and adjust values.
# For local development with docker-compose, the defaults below work as-is.
# For production, change ALL secrets.

# Server
HOST=0.0.0.0
PORT=3000

# Database
# Local dev default matches docker-compose: user=coopdata, password=password
DATABASE_URL=postgresql://coopdata:password@localhost:5432/coopdata

# Redis
REDIS_URL=redis://localhost:6379

# Keycloak (OpenID Connect)
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=coop-data
KEYCLOAK_CLIENT_ID=coopdata-backend
KEYCLOAK_CLIENT_SECRET=change-me-in-production

# JWT Validation
JWT_ISSUER=http://localhost:8180/realms/coop-data
JWT_AUDIENCE=coopdata-frontend

# CORS — allowed frontend origin
FRONTEND_URL=http://localhost:5173

# Environment: development | staging | production
ENVIRONMENT=development